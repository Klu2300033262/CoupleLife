{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "couples": {
      "$coupleId": {
        ".read": "auth != null && root.child('couples').child($coupleId).child('members').child(auth.uid).val() === true",
        ".write": "auth != null && root.child('couples').child($coupleId).child('members').child(auth.uid).val() === true",
        "chat": {
          "$messageId": {
            ".validate": "newData.hasChildren(['senderId', 'text', 'timestamp']) && newData.child('senderId').val() === auth.uid"
          },
          ".indexOn": ["timestamp"]
        },
        "diary": {
          ".indexOn": ["date", "timestamp"]
        }
      }
    }
  }
}
